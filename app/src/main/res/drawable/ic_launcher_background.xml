<?xml version="1.0" encoding="utf-8"?>
<!--
    DayCast App Icon - Background Layer
    Destination: app/src/main/res/drawable/ic_launcher_background.xml

    Diagonal gradient from DayCast primary indigo to deep violet.
    This sits behind the white sunrise foreground.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:startColor="#3949AB"
        android:centerColor="#5C35A8"
        android:endColor="#7B1FA2"
        android:angle="135" />
</shape>
